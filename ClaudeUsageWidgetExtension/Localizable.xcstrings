{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ %@" : {
      "comment" : "A text that appears when a scheduled event is currently happening or has already happened. The argument is the string “countdown.now”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ %lld%@" : {
      "comment" : "A label showing the number of minutes remaining for a task or event. The argument is the string “time.minute”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$lld%3$@"
          }
        }
      }
    },
    "%@ %lld%@ %lld%@" : {
      "comment" : "A text showing how many hours and minutes remain until a reset time. The first argument is a label describing the type of time (e.g., \"next reset in\"). The second and third arguments are the number of hours and minutes, respectively. The third argument is the string “time.hour”. The fifth argument is the string “time.minute”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$lld%3$@ %4$lld%5$@"
          }
        }
      }
    },
    "%lld%%" : {
      "comment" : "A text element showing the current usage of the Claude feature, presented as a percentage. The single argument is the current usage percentage.",
      "isCommentAutoGenerated" : true
    },
    "~/.claude/claude-usage-widget.json" : {
      "comment" : "The path to the configuration file used by the widget.",
      "isCommentAutoGenerated" : true
    },
    "Claude" : {
      "comment" : "The name of the app.",
      "isCommentAutoGenerated" : true
    },
