{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ %@" : {
      "comment" : "A text that appears when a clock timer reaches zero, indicating that an action is currently in progress. The argument is the string “countdown.now”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ %lld%@" : {
      "comment" : "A label displaying the remaining number of minutes. The argument is the string “time.minute”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$lld%3$@"
          }
        }
      }
    },
    "%@ %lld%@ %lld%@" : {
      "comment" : "A countdown timer displaying the remaining time until a reset event, in hours and minutes. The first argument is a string describing the context or purpose of the timer. The second argument is the number of hours remaining. The third argument is the string “time.hour”. The fifth argument is the string “time.minute”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$lld%3$@ %4$lld%5$@"
          }
        }
      }
    },
    "%lld%%" : {
      "comment" : "A large, bold text label displaying the current usage percentage of a health app. The text is styled to be round and has a size of 22 points. The color of the text corresponds to the severity of",
      "isCommentAutoGenerated" : true
    },
